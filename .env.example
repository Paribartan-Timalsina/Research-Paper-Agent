# Postgres
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=research
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis (also used as Celery broker/backend)
REDIS_URL=redis://redis:6379/0

# LLM
LLM_PROVIDER=mock            # mock | gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# App
APP_ENV=dev
LOG_LEVEL=INFO
